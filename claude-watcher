#!/usr/bin/env bash
#
# claude-watcher - Monitor Claude Code sessions across tmux and alert when they need attention
#
# Usage:
#   claude-watcher start [-d]     Start watching (add -d for daemon/background mode)
#   claude-watcher stop           Stop background watcher
#   claude-watcher status         Show all Claude sessions and their state
#   claude-watcher focus [pane]   Bring Terminal to front and switch to alerting pane
#   claude-watcher install        Install Claude Code notification hooks
#   claude-watcher uninstall      Remove Claude Code hooks
#

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks to find the real script location
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
WATCHER_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# ── Configuration ────────────────────────────────────────────────────────────

STATE_DIR="/tmp/claude-watcher"
PID_FILE="$STATE_DIR/watcher.pid"
ALERTS_DIR="$STATE_DIR/alerts"
LOG_FILE="$STATE_DIR/watcher.log"
SCAN_INTERVAL="${CLAUDE_WATCHER_INTERVAL:-3}"
SOUND_FILE="${CLAUDE_WATCHER_SOUND:-/System/Library/Sounds/Glass.aiff}"
AUTO_FOCUS="${CLAUDE_WATCHER_AUTO_FOCUS:-true}"
COOLDOWN="${CLAUDE_WATCHER_COOLDOWN:-30}"
ACTIVE_FILE="$STATE_DIR/active"

mkdir -p "$STATE_DIR" "$ALERTS_DIR"

# ── Colors ───────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Logging ──────────────────────────────────────────────────────────────────

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# ── Terminal detection ───────────────────────────────────────────────────────

detect_terminal_app() {
    local front
    front=$(osascript -e '
        tell application "System Events"
            set appList to name of every application process whose visible is true
        end tell
        if appList contains "iTerm2" then
            return "iTerm2"
        else if appList contains "Terminal" then
            return "Terminal"
        else if appList contains "Alacritty" then
            return "Alacritty"
        else if appList contains "kitty" then
            return "kitty"
        else
            return "Terminal"
        end if
    ' 2>/dev/null || echo "Terminal")
    echo "$front"
}

activate_terminal() {
    local app
    app=$(detect_terminal_app)
    osascript -e "tell application \"$app\" to activate" 2>/dev/null || true
}

# ── tmux helpers ─────────────────────────────────────────────────────────────

# Find all tmux panes running Claude Code
# pane_pid is the shell process; pane_current_command shows what's actively running.
# Claude shows as "node" or its version string (e.g. "2.1.63").
# We verify by checking if a child process of pane_pid is "claude".
find_claude_panes() {
    tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_pid}|#{pane_current_command}|#{session_attached}' 2>/dev/null | while IFS='|' read -r pane pid cmd attached; do
        # Quick filter: skip panes clearly not running claude (plain bash/vim/etc)
        if [[ "$cmd" == "bash" || "$cmd" == "zsh" || "$cmd" == "vim" || "$cmd" == "nvim" || "$cmd" == "ssh" ]]; then
            continue
        fi
        # Check if any child of the shell is a claude process
        if pgrep -qP "$pid" -f "claude" 2>/dev/null; then
            echo "$pane|$pid|$attached"
        fi
    done
}

# Get our own tmux pane (to skip it in scanning)
get_own_pane() {
    tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || echo ""
}

# ── State detection ──────────────────────────────────────────────────────────

detect_pane_state() {
    local pane="$1"
    local content
    content=$(tmux capture-pane -t "$pane" -p -S -30 2>/dev/null || true)

    if [[ -z "$content" ]]; then
        echo "unknown"
        return
    fi

    local last_lines
    last_lines=$(echo "$content" | tail -25)

    # ── Priority 1: Permission prompt ──
    # Claude shows "Allow once", "Always allow", "Deny" as selectable options
    if echo "$last_lines" | grep -qE '(Allow once|Always allow|Allow for this|allow for this session)'; then
        if echo "$last_lines" | grep -q 'Deny'; then
            echo "permission"
            return
        fi
    fi

    # ── Priority 2: Question / Elicitation ──
    # AskUserQuestion shows options with ❯ selector and "Other" at the bottom
    # Pattern: lines with selectable options preceded by a question
    if echo "$last_lines" | grep -qE '^\s+❯\s+\S' 2>/dev/null; then
        # Check it's a question dialog (has multiple options, not the main prompt)
        local option_count
        option_count=$(echo "$last_lines" | grep -cE '^\s+(❯\s+)?\S' 2>/dev/null || echo 0)
        if [[ $option_count -ge 3 ]]; then
            # Likely a selection dialog
            if echo "$last_lines" | grep -qE '(Other|\(Recommended\))$' 2>/dev/null; then
                echo "question"
                return
            fi
        fi
    fi

    # ── Priority 3: Plan approval ──
    if echo "$last_lines" | grep -qi 'awaiting.*approval\|approve.*plan\|Yes.*proceed\|Approve\|Start implementation'; then
        echo "plan_approval"
        return
    fi

    # ── Priority 4: Interrupted ──
    if echo "$last_lines" | grep -q 'Interrupted'; then
        # Check if it's recent (near the bottom)
        if echo "$content" | tail -10 | grep -q 'Interrupted'; then
            echo "interrupted"
            return
        fi
    fi

    # ── Priority 5: Idle ──
    # The bottom status line shows "? for shortcuts" or "⏵⏵ accept edits"
    if echo "$last_lines" | grep -qE '(\? for shortcuts|⏵⏵ accept edits)'; then
        # Check if the prompt line is empty
        local prompt_line
        prompt_line=$(echo "$content" | grep -E '^❯' | tail -1 || true)
        if [[ -z "$prompt_line" ]] || [[ "${prompt_line}" =~ ^❯[[:space:]]*$ ]]; then
            echo "idle"
            return
        fi
        echo "idle_with_input"
        return
    fi

    # ── Default: working ──
    echo "working"
}

# ── Notification ─────────────────────────────────────────────────────────────

send_notification() {
    local title="$1"
    local message="$2"
    local subtitle="${3:-}"

    osascript -e "display notification \"$message\" with title \"$title\" subtitle \"$subtitle\" sound name \"Glass\"" 2>/dev/null &

    # Backup sound in case notification sound doesn't play
    if [[ -f "$SOUND_FILE" ]]; then
        afplay "$SOUND_FILE" 2>/dev/null &
    fi

    log "ALERT: $title | $message | $subtitle"
}

# ── Focus ────────────────────────────────────────────────────────────────────

focus_pane() {
    local pane="$1"
    local session="${pane%%:*}"
    local win_pane="${pane#*:}"

    # Bring terminal app to macOS foreground
    activate_terminal

    # Switch tmux to the right session/window/pane
    tmux switch-client -t "$session" 2>/dev/null || true
    tmux select-window -t "$session:${win_pane%%.*}" 2>/dev/null || true
    tmux select-pane -t "$pane" 2>/dev/null || true

    log "FOCUS: $pane"
}

# ── Alert cooldown ───────────────────────────────────────────────────────────

should_alert() {
    local pane="$1"
    local state="$2"
    local alert_file="$ALERTS_DIR/${pane//[:.]/_}"

    if [[ -f "$alert_file" ]]; then
        local last_state last_alert now elapsed
        last_state=$(head -1 "$alert_file" 2>/dev/null || true)
        last_alert=$(stat -f %m "$alert_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        elapsed=$((now - last_alert))

        if [[ "$last_state" == "$state" ]] && [[ $elapsed -lt $COOLDOWN ]]; then
            return 1
        fi
    fi

    echo "$state" > "$alert_file"
    return 0
}

clear_alert() {
    local pane="$1"
    local alert_file="$ALERTS_DIR/${pane//[:.]/_}"
    rm -f "$alert_file"
}

# ── Scanner ──────────────────────────────────────────────────────────────────

scan_once() {
    local our_pane
    our_pane=$(get_own_pane)

    while IFS='|' read -r pane pid attached; do
        [[ "$pane" == "$our_pane" ]] && continue

        local state
        state=$(detect_pane_state "$pane")
        local session_name="${pane%%:*}"

        case "$state" in
            permission)
                if should_alert "$pane" "$state"; then
                    send_notification "Claude needs permission" "[$pane] Waiting for Allow/Deny" "$session_name"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            question)
                if should_alert "$pane" "$state"; then
                    send_notification "Claude has a question" "[$pane] Asking you a question" "$session_name"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            plan_approval)
                if should_alert "$pane" "$state"; then
                    send_notification "Claude plan ready" "[$pane] Awaiting plan approval" "$session_name"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            interrupted)
                if should_alert "$pane" "$state"; then
                    send_notification "Claude interrupted" "[$pane] Needs direction after interrupt" "$session_name"
                fi
                ;;
            idle|working|idle_with_input)
                clear_alert "$pane"
                ;;
        esac
    done < <(find_claude_panes)
}

# ── Daemon ───────────────────────────────────────────────────────────────────

run_loop() {
    trap 'rm -f "$PID_FILE"; log "Watcher stopped"; exit 0' INT TERM
    echo $$ > "$PID_FILE"
    log "Watcher started (PID: $$, interval: ${SCAN_INTERVAL}s)"

    while true; do
        scan_once 2>/dev/null || true
        sleep "$SCAN_INTERVAL"
    done
}

cmd_start() {
    local daemon=false
    [[ "${1:-}" == "-d" || "${1:-}" == "--daemon" ]] && daemon=true

    # Mark watcher as active (hooks check this before sending notifications)
    touch "$ACTIVE_FILE"

    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo -e "${YELLOW}Watcher already running (PID: $(cat "$PID_FILE"))${NC}"
        return 1
    fi

    local pane_count
    pane_count=$(find_claude_panes | wc -l | tr -d ' ')

    if $daemon; then
        echo -e "${GREEN}Starting Claude Watcher daemon...${NC}"
        nohup "$0" _loop >> "$LOG_FILE" 2>&1 &
        local pid=$!
        echo $pid > "$PID_FILE"
        echo -e "${GREEN}  Started${NC} (PID: $pid)"
        echo -e "${DIM}  Monitoring $pane_count Claude session(s)${NC}"
        echo -e "${DIM}  Scan interval: ${SCAN_INTERVAL}s | Auto-focus: $AUTO_FOCUS${NC}"
        echo -e "${DIM}  Log: $LOG_FILE${NC}"
    else
        echo -e "${BOLD}Claude Watcher${NC} ${DIM}(Ctrl+C to stop)${NC}"
        echo -e "${DIM}Monitoring $pane_count Claude session(s) | Scan: ${SCAN_INTERVAL}s | Auto-focus: $AUTO_FOCUS${NC}"
        echo ""
        run_loop
    fi
}

cmd_stop() {
    # Remove active flag so hooks stop sending notifications
    rm -f "$ACTIVE_FILE"

    if [[ ! -f "$PID_FILE" ]]; then
        echo -e "${GREEN}Notifications disabled${NC}"
        return 0
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        rm -f "$PID_FILE"
        echo -e "${GREEN}Watcher stopped${NC} (was PID: $pid)"
    else
        rm -f "$PID_FILE"
        echo -e "${GREEN}Notifications disabled${NC} (daemon was already gone)"
    fi
}

# ── Status display ───────────────────────────────────────────────────────────

cmd_status() {
    echo ""
    echo -e "  ${BOLD}Claude Watcher - Session Status${NC}"
    echo -e "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local count=0
    local attention_count=0
    local our_pane
    our_pane=$(get_own_pane)

    while IFS='|' read -r pane pid attached; do
        count=$((count + 1))
        local state
        state=$(detect_pane_state "$pane")

        local icon color label
        case "$state" in
            permission)    icon="⚠ " ; color="$RED"     ; label="NEEDS PERMISSION"  ; attention_count=$((attention_count + 1)) ;;
            question)      icon="? " ; color="$YELLOW"   ; label="ASKING QUESTION"   ; attention_count=$((attention_count + 1)) ;;
            plan_approval) icon="📋" ; color="$YELLOW"   ; label="PLAN APPROVAL"     ; attention_count=$((attention_count + 1)) ;;
            interrupted)   icon="⏸ " ; color="$MAGENTA"  ; label="INTERRUPTED"       ; attention_count=$((attention_count + 1)) ;;
            idle)          icon="◯ " ; color="$CYAN"     ; label="IDLE"              ;;
            idle_with_input) icon="◎ " ; color="$BLUE"   ; label="HAS INPUT"         ;;
            working)       icon="● " ; color="$GREEN"    ; label="WORKING"           ;;
            *)             icon="? " ; color="$DIM"      ; label="UNKNOWN"           ;;
        esac

        local suffix=""
        [[ "$pane" == "$our_pane" ]] && suffix=" ${DIM}← you${NC}"

        printf "  ${color}%s${NC} ${BOLD}%-28s${NC} ${color}%-18s${NC}%s\n" \
            "$icon" "$pane" "$label" "$suffix"
    done < <(find_claude_panes)

    if [[ $count -eq 0 ]]; then
        echo -e "  ${DIM}No Claude sessions found in tmux${NC}"
    fi

    echo ""

    # Watcher status
    if [[ -f "$ACTIVE_FILE" ]]; then
        echo -e "  ${GREEN}●${NC} Notifications: ${GREEN}active${NC}"
    else
        echo -e "  ${DIM}○ Notifications: disabled${NC} (run 'claude-watcher start' to enable)"
    fi
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo -e "  ${GREEN}●${NC} Scanner daemon: ${GREEN}running${NC} (PID: $(cat "$PID_FILE"))"
    else
        echo -e "  ${DIM}○ Scanner daemon: not running${NC}"
    fi

    # Summary
    if [[ $attention_count -gt 0 ]]; then
        echo -e "  ${RED}${BOLD}$attention_count session(s) need your attention!${NC}"
    fi

    echo ""
}

# ── Focus command ────────────────────────────────────────────────────────────

cmd_focus() {
    local target="${1:-}"

    if [[ -n "$target" ]]; then
        focus_pane "$target"
        echo -e "${GREEN}Focused: $target${NC}"
        return
    fi

    # Auto-find first session needing attention
    while IFS='|' read -r pane pid attached; do
        local state
        state=$(detect_pane_state "$pane")
        case "$state" in
            permission|question|plan_approval|interrupted)
                focus_pane "$pane"
                echo -e "${GREEN}Focused: $pane${NC} ($state)"
                return
                ;;
        esac
    done < <(find_claude_panes)

    echo -e "${DIM}No sessions currently need attention${NC}"
}

# ── Hook installation ────────────────────────────────────────────────────────

cmd_install() {
    local settings_file="$HOME/.claude/settings.json"
    local hook_script="$WATCHER_DIR/on-claude-notify.sh"

    if [[ ! -f "$hook_script" ]]; then
        echo -e "${RED}Hook script not found: $hook_script${NC}"
        return 1
    fi

    chmod +x "$hook_script"
    chmod +x "$WATCHER_DIR/claude-watcher"

    if [[ ! -f "$settings_file" ]]; then
        echo -e "${RED}Claude settings not found: $settings_file${NC}"
        return 1
    fi

    node -e "
        const fs = require('fs');
        const settings = JSON.parse(fs.readFileSync('$settings_file', 'utf8'));

        settings.hooks = settings.hooks || {};

        // ── Notification hook (permission_prompt only) ──
        settings.hooks.Notification = (settings.hooks.Notification || []).filter(
            h => !h.hooks?.some(c => c.command?.includes('on-claude-notify'))
        );
        settings.hooks.Notification.push({
            matcher: 'permission_prompt',
            hooks: [{ type: 'command', command: '$hook_script' }]
        });

        // ── Elicitation hook (questions) ──
        settings.hooks.Elicitation = (settings.hooks.Elicitation || []).filter(
            h => !h.hooks?.some(c => c.command?.includes('on-claude-notify'))
        );
        settings.hooks.Elicitation.push({
            matcher: '',
            hooks: [{ type: 'command', command: '$hook_script' }]
        });

        // ── PermissionRequest hook ──
        settings.hooks.PermissionRequest = (settings.hooks.PermissionRequest || []).filter(
            h => !h.hooks?.some(c => c.command?.includes('on-claude-notify'))
        );
        settings.hooks.PermissionRequest.push({
            matcher: '',
            hooks: [{ type: 'command', command: '$hook_script' }]
        });

        fs.writeFileSync('$settings_file', JSON.stringify(settings, null, 2));
    "

    echo -e "${GREEN}Hooks installed successfully!${NC}"
    echo -e "${DIM}  Settings: $settings_file${NC}"
    echo -e "${DIM}  Handler:  $hook_script${NC}"
    echo ""
    echo -e "  ${YELLOW}Note: Restart running Claude sessions for hooks to take effect.${NC}"
}

cmd_uninstall() {
    local settings_file="$HOME/.claude/settings.json"

    node -e "
        const fs = require('fs');
        const settings = JSON.parse(fs.readFileSync('$settings_file', 'utf8'));

        if (settings.hooks) {
            for (const [key, hooks] of Object.entries(settings.hooks)) {
                settings.hooks[key] = hooks.filter(
                    h => !h.hooks?.some(c => c.command?.includes('on-claude-notify'))
                );
                if (settings.hooks[key].length === 0) delete settings.hooks[key];
            }
            if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
        }

        fs.writeFileSync('$settings_file', JSON.stringify(settings, null, 2));
    "

    echo -e "${GREEN}Hooks removed from Claude settings${NC}"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    start)     cmd_start "${2:-}" ;;
    stop)      cmd_stop ;;
    status|s)  cmd_status ;;
    focus|f)   cmd_focus "${2:-}" ;;
    install)   cmd_install ;;
    uninstall) cmd_uninstall ;;
    _loop)     run_loop ;;
    help|--help|-h)
        echo ""
        echo -e "  ${BOLD}claude-watcher${NC} — Monitor Claude Code sessions across tmux"
        echo ""
        echo -e "  ${BOLD}COMMANDS${NC}"
        echo -e "    start [-d]     Start watching (-d for daemon mode)"
        echo -e "    stop           Stop the background watcher"
        echo -e "    status         Show all Claude sessions and their state"
        echo -e "    focus [pane]   Bring terminal to front, switch to alerting pane"
        echo -e "    install        Install Claude Code notification hooks"
        echo -e "    uninstall      Remove hooks from Claude settings"
        echo ""
        echo -e "  ${BOLD}ENVIRONMENT${NC}"
        echo -e "    CLAUDE_WATCHER_INTERVAL     Scan interval in seconds (default: 3)"
        echo -e "    CLAUDE_WATCHER_SOUND        Sound file path (default: Glass.aiff)"
        echo -e "    CLAUDE_WATCHER_AUTO_FOCUS   Auto-focus on alert (default: true)"
        echo -e "    CLAUDE_WATCHER_COOLDOWN     Repeat alert cooldown in seconds (default: 30)"
        echo ""
        echo -e "  ${BOLD}HOW IT WORKS${NC}"
        echo -e "    Two detection methods work together:"
        echo -e "    1. ${GREEN}Hooks${NC} (real-time): Claude fires events → instant notification"
        echo -e "    2. ${GREEN}Scanner${NC} (polling): Scans tmux panes every few seconds"
        echo ""
        echo -e "  ${BOLD}QUICK START${NC}"
        echo -e "    claude-watcher install       # Set up Claude hooks"
        echo -e "    claude-watcher start -d      # Start background watcher"
        echo -e "    claude-watcher status        # See all sessions"
        echo ""
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC} — run 'claude-watcher help' for usage"
        exit 1
        ;;
esac
