#!/usr/bin/env bash
#
# claude-watcher - Monitor Claude Code sessions and alert when they need attention
#
# Works with or without tmux:
#   - With tmux: full scanner + hooks + popup dialogs + pane auto-focus
#   - Without tmux: hooks + popup dialogs (scanner disabled)
#
# Usage:
#   claude-watcher start [-d]     Start watching (add -d for daemon/background mode)
#   claude-watcher stop           Stop background watcher
#   claude-watcher status         Show all Claude sessions and their state
#   claude-watcher focus [pane]   Bring Terminal to front and switch to alerting pane
#   claude-watcher install        Install Claude Code notification hooks
#   claude-watcher uninstall      Remove Claude Code hooks
#

set -euo pipefail

# Ensure Homebrew tools (tmux, terminal-notifier, node) are in PATH
for p in /opt/homebrew/bin /usr/local/bin; do
    [[ -d "$p" && ":$PATH:" != *":$p:"* ]] && export PATH="$p:$PATH"
done

SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks to find the real script location
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
WATCHER_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# ── Configuration ────────────────────────────────────────────────────────────

STATE_DIR="/tmp/claude-watcher"
PID_FILE="$STATE_DIR/watcher.pid"
POPUP_PID_FILE="$STATE_DIR/daemon.pid"
ALERTS_DIR="$STATE_DIR/alerts"
QUEUE_DIR="$STATE_DIR/popup-queue"
LOG_FILE="$STATE_DIR/watcher.log"
SCAN_INTERVAL="${CLAUDE_WATCHER_INTERVAL:-3}"
SOUND_FILE="${CLAUDE_WATCHER_SOUND:-/System/Library/Sounds/Glass.aiff}"
AUTO_FOCUS="${CLAUDE_WATCHER_AUTO_FOCUS:-false}"
COOLDOWN="${CLAUDE_WATCHER_COOLDOWN:-30}"
ACTIVE_FILE="$STATE_DIR/active"
SESSION_STATE_DIR="$STATE_DIR/session-state"
POPUP_SCRIPT="$WATCHER_DIR/popup-daemon.js"
QUEUE_HOOKS_DIR="$STATE_DIR/queue/hooks"
QUEUE_SCANNER_DIR="$STATE_DIR/queue/scanner"
REPLY_DIR="$STATE_DIR/reply"
DAEMON_STATUS_FILE="$STATE_DIR/daemon-status.json"

mkdir -p "$STATE_DIR" "$ALERTS_DIR" "$QUEUE_DIR" "$SESSION_STATE_DIR" "$QUEUE_HOOKS_DIR" "$QUEUE_SCANNER_DIR" "$REPLY_DIR"

# Detect tmux availability
HAS_TMUX=false
if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null; then
    HAS_TMUX=true
fi

# ── Colors ───────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Logging ──────────────────────────────────────────────────────────────────

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# Escape a string for safe interpolation into AppleScript double-quoted strings
as_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }


# ── Terminal detection ───────────────────────────────────────────────────────

detect_terminal_app() {
    local front
    front=$(osascript -e '
        tell application "System Events"
            set appList to name of every application process whose visible is true
        end tell
        if appList contains "iTerm2" then
            return "iTerm2"
        else if appList contains "Alacritty" then
            return "Alacritty"
        else if appList contains "kitty" then
            return "kitty"
        else if appList contains "WezTerm" then
            return "WezTerm"
        else if appList contains "Hyper" then
            return "Hyper"
        else if appList contains "Terminal" then
            return "Terminal"
        else
            return "Terminal"
        end if
    ' 2>/dev/null || echo "Terminal")
    echo "$front"
}

activate_terminal() {
    local app
    app=$(detect_terminal_app)
    osascript -e "tell application \"$app\" to activate" 2>/dev/null || true
}

# ── tmux helpers ─────────────────────────────────────────────────────────────
# These functions are no-ops when tmux is not available.

# Find all tmux panes running Claude Code
find_claude_panes() {
    [[ "$HAS_TMUX" != "true" ]] && return 0

    tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_pid}|#{pane_current_command}|#{session_attached}' 2>/dev/null | while IFS='|' read -r pane pid cmd attached; do
        # Quick filter: skip panes clearly not running claude (plain bash/vim/etc)
        if [[ "$cmd" == "bash" || "$cmd" == "zsh" || "$cmd" == "vim" || "$cmd" == "nvim" || "$cmd" == "ssh" ]]; then
            continue
        fi
        # Check if any child of the shell is a claude process
        if pgrep -qP "$pid" -f "claude" 2>/dev/null; then
            echo "$pane|$pid|$attached"
        fi
    done
}

# Get our own tmux pane (to skip it in scanning)
get_own_pane() {
    if [[ "$HAS_TMUX" == "true" ]]; then
        tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || echo ""
    else
        echo ""
    fi
}

# ── State detection ──────────────────────────────────────────────────────────

detect_pane_state() {
    local pane="$1"
    [[ "$HAS_TMUX" != "true" ]] && { echo "unknown"; return; }

    local content
    content=$(tmux capture-pane -t "$pane" -p -S -30 2>/dev/null || true)

    if [[ -z "$content" ]]; then
        echo "unknown"
        return
    fi

    local last_lines
    last_lines=$(echo "$content" | tail -25)

    # ── Priority 1: Permission prompt ──
    if echo "$last_lines" | grep -qE '(Allow once|Always allow|Allow for this|allow for this session)'; then
        if echo "$last_lines" | grep -q 'Deny'; then
            echo "permission"
            return
        fi
    fi

    # ── Priority 2: Question / Elicitation ──
    if echo "$last_lines" | grep -qE '^\s+❯\s+\S' 2>/dev/null; then
        local option_count
        option_count=$(echo "$last_lines" | grep -cE '^\s+(❯\s+)?\S' 2>/dev/null || echo 0)
        if [[ $option_count -ge 3 ]]; then
            if echo "$last_lines" | grep -qE '(Other|\(Recommended\))$' 2>/dev/null; then
                echo "question"
                return
            fi
        fi
    fi

    # ── Priority 3: Idle ──
    # Detect idle by either:
    #   a) Classic indicators (? for shortcuts / ⏵⏵ accept edits) visible, OR
    #   b) An empty ❯ prompt followed by the status bar (Model: line)
    local has_classic_idle=false
    if echo "$last_lines" | grep -qE '(\? for shortcuts|⏵⏵ accept edits)'; then
        has_classic_idle=true
    fi

    local has_empty_prompt=false
    # Check if the last ❯ line is empty (no user input yet) and status bar is visible
    if echo "$last_lines" | grep -qE '^❯\s*$'; then
        if echo "$last_lines" | grep -qE '^\s+Model:'; then
            has_empty_prompt=true
        fi
    fi

    if [[ "$has_classic_idle" == "true" || "$has_empty_prompt" == "true" ]]; then
        local prompt_line
        prompt_line=$(echo "$content" | grep -E '^❯' | tail -1 || true)
        if [[ -z "$prompt_line" ]] || [[ "${prompt_line}" =~ ^❯[[:space:]]*$ ]]; then
            echo "idle"
            return
        fi
        echo "idle_with_input"
        return
    fi

    # ── Priority 4: Plan approval ──
    if echo "$last_lines" | grep -qi 'awaiting.*approval\|approve.*plan\|Yes.*proceed\|Approve\|Start implementation'; then
        echo "plan_approval"
        return
    fi

    # ── Priority 5: Interrupted ──
    if echo "$last_lines" | grep -q 'Interrupted'; then
        if echo "$content" | tail -10 | grep -q 'Interrupted'; then
            echo "interrupted"
            return
        fi
    fi

    # ── Default: working ──
    echo "working"
}

# ── Notification ─────────────────────────────────────────────────────────────

send_notification() {
    local title="$1"
    local message="$2"
    local subtitle="${3:-}"
    local pane="${4:-}"

    # Use terminal-notifier if available — clicking the notification focuses the pane
    if command -v terminal-notifier &>/dev/null; then
        local tn_args=(-title "$title" -message "$message" -sound Glass -group "claude-$pane")
        [[ -n "$subtitle" ]] && tn_args+=(-subtitle "$subtitle")
        if [[ -n "$pane" ]]; then
            tn_args+=(-execute "$WATCHER_DIR/claude-watcher focus $pane")
        fi
        terminal-notifier "${tn_args[@]}" &>/dev/null &
    else
        osascript -e "display notification \"$(as_escape "$message")\" with title \"$(as_escape "$title")\" subtitle \"$(as_escape "$subtitle")\" sound name \"Glass\"" 2>/dev/null &
    fi

    if [[ -f "$SOUND_FILE" ]]; then
        afplay "$SOUND_FILE" 2>/dev/null &
    fi

    log "ALERT: $title | $message | $subtitle | pane=$pane"
}

# ── Focus ────────────────────────────────────────────────────────────────────

focus_pane() {
    local pane="$1"

    # Always bring terminal app to macOS foreground
    activate_terminal

    # If tmux is available, switch to the right session/window/pane
    if [[ "$HAS_TMUX" == "true" && -n "$pane" && "$pane" != "unknown" && "$pane" != "no-tmux" ]]; then
        local session="${pane%%:*}"
        local win_pane="${pane#*:}"
        # Find the most recent attached client (needed when run outside tmux, e.g. notification click)
        local client
        client=$(tmux list-clients -F '#{client_name}' 2>/dev/null | head -1)
        if [[ -n "$client" ]]; then
            tmux switch-client -c "$client" -t "$session" 2>/dev/null || true
        fi
        tmux select-window -t "$session:${win_pane%%.*}" 2>/dev/null || true
        tmux select-pane -t "$pane" 2>/dev/null || true
    fi

    log "FOCUS: ${pane:-terminal}"
}

# ── Alert cooldown ───────────────────────────────────────────────────────────

should_alert() {
    local pane="$1"
    local state="$2"
    local alert_file="$ALERTS_DIR/${pane//[:.]/_}"

    if [[ -f "$alert_file" ]]; then
        local last_state last_alert now elapsed
        last_state=$(head -1 "$alert_file" 2>/dev/null || true)
        last_alert=$(stat -f %m "$alert_file" 2>/dev/null || echo 0)
        now=$(date +%s)
        elapsed=$((now - last_alert))

        if [[ "$last_state" == "$state" ]] && [[ $elapsed -lt $COOLDOWN ]]; then
            return 1
        fi
    fi

    echo "$state" > "$alert_file"
    return 0
}

clear_alert() {
    local pane="$1"
    local alert_file="$ALERTS_DIR/${pane//[:.]/_}"
    rm -f "$alert_file"
}

# ── NATS publishing helper ───────────────────────────────────────────────────

# Publish a JSON message to a NATS subject.
# Falls back to writing to a file queue directory if NATS is unavailable.
# Usage: nats_publish <subject> <json_payload> <fallback_dir>
nats_publish() {
    local subject="$1"
    local payload="$2"
    local fallback_dir="$3"

    local _ts
    _ts=$(node -e "process.stdout.write(String(Date.now()))" 2>/dev/null || echo "$(date +%s)000")

    # Node connect has its own 2s timeout — no external timeout needed
    if node -e "
        const nats = require('nats');
        (async () => {
            try {
                const nc = await nats.connect({ servers: 'nats://localhost:4222', timeout: 2000 });
                nc.publish('${subject}', Buffer.from(JSON.stringify(JSON.parse(process.argv[1]))));
                await nc.flush();
                await nc.close();
            } catch (e) {
                process.exit(1);
            }
        })();
    " "$payload" 2>/dev/null; then
        return 0
    else
        # NATS unavailable — write to file queue fallback
        mkdir -p "$fallback_dir"
        echo "$payload" > "${fallback_dir}/${_ts}-scanner-$$.json"
        log "NATS unavailable, wrote to file queue: ${fallback_dir}/${_ts}-scanner-$$.json"
        return 1
    fi
}

# ── Scanner (tmux only) ─────────────────────────────────────────────────────

scan_once() {
    [[ "$HAS_TMUX" != "true" ]] && return 0

    local our_pane
    our_pane=$(get_own_pane)

    while IFS='|' read -r pane pid attached; do
        [[ "$pane" == "$our_pane" ]] && continue

        local state
        state=$(detect_pane_state "$pane")
        local session_name="${pane%%:*}"

        case "$state" in
            permission)
                if should_alert "$pane" "$state"; then
                    # Publish to NATS scanner subject, fall back to file queue
                    local scanner_payload
                    scanner_payload=$(node -e "process.stdout.write(JSON.stringify({
                        type: 'scanner',
                        state: 'permission',
                        pane: process.argv[1],
                        session_name: process.argv[2],
                        message: 'Waiting for Allow/Deny',
                        timestamp: Date.now()
                    }))" "$pane" "$session_name" 2>/dev/null || echo "")
                    if [[ -n "$scanner_payload" ]]; then
                        nats_publish "claude.scanner" "$scanner_payload" "$QUEUE_SCANNER_DIR" 2>/dev/null || true
                    fi
                    send_notification "Claude needs permission" "[$pane] Waiting for Allow/Deny" "$session_name" "$pane"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            question)
                if should_alert "$pane" "$state"; then
                    local scanner_payload
                    scanner_payload=$(node -e "process.stdout.write(JSON.stringify({
                        type: 'scanner',
                        state: 'question',
                        pane: process.argv[1],
                        session_name: process.argv[2],
                        message: 'Asking you a question',
                        timestamp: Date.now()
                    }))" "$pane" "$session_name" 2>/dev/null || echo "")
                    if [[ -n "$scanner_payload" ]]; then
                        nats_publish "claude.scanner" "$scanner_payload" "$QUEUE_SCANNER_DIR" 2>/dev/null || true
                    fi
                    send_notification "Claude has a question" "[$pane] Asking you a question" "$session_name" "$pane"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            plan_approval)
                if should_alert "$pane" "$state"; then
                    local scanner_payload
                    scanner_payload=$(node -e "process.stdout.write(JSON.stringify({
                        type: 'scanner',
                        state: 'plan_approval',
                        pane: process.argv[1],
                        session_name: process.argv[2],
                        message: 'Awaiting plan approval',
                        timestamp: Date.now()
                    }))" "$pane" "$session_name" 2>/dev/null || echo "")
                    if [[ -n "$scanner_payload" ]]; then
                        nats_publish "claude.scanner" "$scanner_payload" "$QUEUE_SCANNER_DIR" 2>/dev/null || true
                    fi
                    send_notification "Claude plan ready" "[$pane] Awaiting plan approval" "$session_name" "$pane"
                    [[ "$AUTO_FOCUS" == "true" ]] && focus_pane "$pane"
                fi
                ;;
            interrupted)
                if should_alert "$pane" "$state"; then
                    local scanner_payload
                    scanner_payload=$(node -e "process.stdout.write(JSON.stringify({
                        type: 'scanner',
                        state: 'interrupted',
                        pane: process.argv[1],
                        session_name: process.argv[2],
                        message: 'Needs direction after interrupt',
                        timestamp: Date.now()
                    }))" "$pane" "$session_name" 2>/dev/null || echo "")
                    if [[ -n "$scanner_payload" ]]; then
                        nats_publish "claude.scanner" "$scanner_payload" "$QUEUE_SCANNER_DIR" 2>/dev/null || true
                    fi
                    send_notification "Claude interrupted" "[$pane] Needs direction after interrupt" "$session_name" "$pane"
                fi
                ;;
            idle|working|idle_with_input)
                clear_alert "$pane"
                ;;
        esac
    done < <(find_claude_panes)
}

# ── Daemon ───────────────────────────────────────────────────────────────────

run_loop() {
    trap 'rm -f "$PID_FILE"; log "Watcher stopped"; exit 0' INT TERM
    echo $$ > "$PID_FILE"
    log "Watcher started (PID: $$, interval: ${SCAN_INTERVAL}s, tmux: $HAS_TMUX)"

    while true; do
        scan_once 2>/dev/null || true
        sleep "$SCAN_INTERVAL"
    done
}

start_popup_daemon() {
    if [[ -f "$POPUP_PID_FILE" ]] && kill -0 "$(cat "$POPUP_PID_FILE")" 2>/dev/null; then
        return 0  # already running
    fi
    nohup node "$POPUP_SCRIPT" >> "$LOG_FILE" 2>&1 &
    echo $! > "$POPUP_PID_FILE"
    log "Popup daemon started (PID: $!)"
}

stop_popup_daemon() {
    if [[ ! -f "$POPUP_PID_FILE" ]]; then
        return 0
    fi
    local pid
    pid=$(cat "$POPUP_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        log "Popup daemon stopped (PID: $pid)"
    fi
    rm -f "$POPUP_PID_FILE"
}

cmd_start() {
    local daemon=false
    [[ "${1:-}" == "-d" || "${1:-}" == "--daemon" ]] && daemon=true

    # Mark watcher as active (hooks check this before sending notifications)
    touch "$ACTIVE_FILE"

    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo -e "${YELLOW}Watcher already running (PID: $(cat "$PID_FILE"))${NC}"
        return 1
    fi

    local pane_count=0
    if [[ "$HAS_TMUX" == "true" ]]; then
        pane_count=$(find_claude_panes | wc -l | tr -d ' ')
    fi

    if $daemon; then
        echo -e "${GREEN}Starting Claude Watcher daemon...${NC}"
        if [[ "$HAS_TMUX" == "true" ]]; then
            nohup "$0" _loop >> "$LOG_FILE" 2>&1 &
            local pid=$!
            echo $pid > "$PID_FILE"
            echo -e "${GREEN}  Scanner started${NC} (PID: $pid)"
            echo -e "${DIM}  Monitoring $pane_count Claude session(s) in tmux${NC}"
            echo -e "${DIM}  Scan interval: ${SCAN_INTERVAL}s | Auto-focus: $AUTO_FOCUS${NC}"
        else
            echo -e "${DIM}  Scanner skipped (tmux not available)${NC}"
        fi
        start_popup_daemon
        echo -e "${GREEN}  Popup daemon started${NC} (PID: $(cat "$POPUP_PID_FILE" 2>/dev/null || echo '?'))"
        echo -e "${GREEN}  Hooks active${NC} (PermissionRequest + Elicitation respond via GUI popup)"
        echo -e "${DIM}  Log: $LOG_FILE${NC}"
    else
        echo -e "${BOLD}Claude Watcher${NC} ${DIM}(Ctrl+C to stop)${NC}"
        if [[ "$HAS_TMUX" == "true" ]]; then
            echo -e "${DIM}Monitoring $pane_count Claude session(s) in tmux | Scan: ${SCAN_INTERVAL}s | Auto-focus: $AUTO_FOCUS${NC}"
        else
            echo -e "${DIM}Hooks mode (no tmux) — popup dialogs for permissions & questions${NC}"
        fi
        echo ""
        start_popup_daemon
        if [[ "$HAS_TMUX" == "true" ]]; then
            run_loop
        else
            # No scanner loop needed — just keep the popup daemon alive
            trap 'stop_popup_daemon; rm -f "$ACTIVE_FILE"; log "Watcher stopped (no-tmux)"; exit 0' INT TERM
            log "Watcher started in hooks-only mode (no tmux)"
            echo -e "${DIM}Running in hooks-only mode. Popup daemon handles GUI dialogs.${NC}"
            echo -e "${DIM}Press Ctrl+C to stop.${NC}"
            while true; do sleep 5; done
        fi
    fi
}

cmd_stop() {
    # Remove active flag so hooks stop sending notifications
    rm -f "$ACTIVE_FILE"
    rm -rf "$STATE_DIR/always-allow"
    rm -rf "$SESSION_STATE_DIR"
    rm -rf "$REPLY_DIR"

    # Recreate directories for clean state
    mkdir -p "$QUEUE_HOOKS_DIR" "$QUEUE_SCANNER_DIR" "$REPLY_DIR" "$SESSION_STATE_DIR"

    stop_popup_daemon

    if [[ ! -f "$PID_FILE" ]]; then
        echo -e "${GREEN}Notifications disabled${NC}"
        return 0
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        rm -f "$PID_FILE"
        echo -e "${GREEN}Watcher stopped${NC} (was PID: $pid)"
    else
        rm -f "$PID_FILE"
        echo -e "${GREEN}Notifications disabled${NC} (daemon was already gone)"
    fi
}

# ── Status display ───────────────────────────────────────────────────────────

cmd_status() {
    echo ""
    echo -e "  ${BOLD}Claude Watcher - Status${NC}"
    echo -e "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local count=0
    local attention_count=0
    local now
    now=$(date +%s)
    local stale_threshold=300  # 5 minutes

    # Clean up state files older than 2 hours
    find "$SESSION_STATE_DIR" -type f -mmin +120 -delete 2>/dev/null || true

    # ── Primary source: hook-based session state files ──
    local seen_panes=()
    local has_state_files=false

    for state_file in "$SESSION_STATE_DIR"/*; do
        [[ -f "$state_file" ]] || continue
        has_state_files=true

        # Source the key=value file into local vars
        local s_state="" s_pane="" s_project="" s_session_id="" s_tool="" s_message="" s_timestamp=""
        while IFS='=' read -r key val; do
            case "$key" in
                state)      s_state="$val" ;;
                pane)       s_pane="$val" ;;
                project)    s_project="$val" ;;
                session_id) s_session_id="$val" ;;
                tool)       s_tool="$val" ;;
                message)    s_message="$val" ;;
                timestamp)  s_timestamp="$val" ;;
            esac
        done < "$state_file"

        [[ -z "$s_state" ]] && continue

        # Check staleness
        local age=$(( now - ${s_timestamp:-0} ))
        if [[ $age -gt $stale_threshold ]]; then
            s_state="stale"
        fi

        count=$((count + 1))
        [[ -n "$s_pane" ]] && seen_panes+=("$s_pane")

        local icon color label
        case "$s_state" in
            permission)    icon="⚠ " ; color="$RED"     ; label="NEEDS PERMISSION"  ; attention_count=$((attention_count + 1)) ;;
            question)      icon="? " ; color="$YELLOW"   ; label="ASKING QUESTION"   ; attention_count=$((attention_count + 1)) ;;
            idle)          icon="◯ " ; color="$CYAN"     ; label="IDLE"              ;;
            working)       icon="● " ; color="$GREEN"    ; label="WORKING"           ;;
            stale)         icon="◌ " ; color="$DIM"      ; label="STALE"             ;;
            *)             icon="? " ; color="$DIM"      ; label="UNKNOWN"           ;;
        esac

        # Build display name: prefer "pane — project", fall back to project
        local display_name="${s_project:-unknown}"
        if [[ -n "$s_pane" && "$s_pane" != "no-tmux" && "$s_pane" != "unknown" ]]; then
            display_name="$s_pane"
        fi

        local tool_info=""
        [[ -n "$s_tool" && "$s_state" != "idle" && "$s_state" != "stale" ]] && tool_info=" ${DIM}($s_tool)${NC}"

        # Check if this is our own pane
        local suffix=""
        if [[ "$HAS_TMUX" == "true" ]]; then
            local our_pane
            our_pane=$(get_own_pane)
            [[ "$s_pane" == "$our_pane" ]] && suffix=" ${DIM}← you${NC}"
        fi

        printf "  %b%s%b %b%-28s%b %b%-18s%b%b%b\n" \
            "$color" "$icon" "$NC" "$BOLD" "$display_name" "$NC" "$color" "$label" "$NC" "$tool_info" "$suffix"
    done

    # ── Fallback: tmux panes not covered by state files ──
    if [[ "$HAS_TMUX" == "true" ]]; then
        local our_pane
        our_pane=$(get_own_pane)

        while IFS='|' read -r pane pid attached; do
            [[ "$pane" == "$our_pane" ]] && continue

            # Skip panes already reported via state files
            local already_seen=false
            for sp in "${seen_panes[@]+"${seen_panes[@]}"}"; do
                [[ "$sp" == "$pane" ]] && { already_seen=true; break; }
            done
            [[ "$already_seen" == "true" ]] && continue

            count=$((count + 1))
            local state
            state=$(detect_pane_state "$pane")

            local icon color label
            case "$state" in
                permission)    icon="⚠ " ; color="$RED"     ; label="NEEDS PERMISSION"  ; attention_count=$((attention_count + 1)) ;;
                question)      icon="? " ; color="$YELLOW"   ; label="ASKING QUESTION"   ; attention_count=$((attention_count + 1)) ;;
                plan_approval) icon="📋" ; color="$YELLOW"   ; label="PLAN APPROVAL"     ; attention_count=$((attention_count + 1)) ;;
                interrupted)   icon="⏸ " ; color="$MAGENTA"  ; label="INTERRUPTED"       ; attention_count=$((attention_count + 1)) ;;
                idle)          icon="◯ " ; color="$CYAN"     ; label="IDLE"              ;;
                idle_with_input) icon="◎ " ; color="$BLUE"   ; label="HAS INPUT"         ;;
                working)       icon="● " ; color="$GREEN"    ; label="WORKING"           ;;
                *)             icon="? " ; color="$DIM"      ; label="UNKNOWN"           ;;
            esac

            printf "  %b%s%b %b%-28s%b %b%-18s%b ${DIM}(tmux)${NC}\n" \
                "$color" "$icon" "$NC" "$BOLD" "$pane" "$NC" "$color" "$label" "$NC"
        done < <(find_claude_panes)
    fi

    if [[ $count -eq 0 ]]; then
        echo -e "  ${DIM}No Claude sessions found${NC}"
    fi

    echo ""

    # Watcher status
    if [[ -f "$ACTIVE_FILE" ]]; then
        echo -e "  ${GREEN}●${NC} Notifications: ${GREEN}active${NC}"
    else
        echo -e "  ${DIM}○ Notifications: disabled${NC} (run 'claude-watcher start' to enable)"
    fi
    if [[ "$HAS_TMUX" == "true" ]]; then
        if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo -e "  ${GREEN}●${NC} Scanner daemon: ${GREEN}running${NC} (PID: $(cat "$PID_FILE"))"
        else
            echo -e "  ${DIM}○ Scanner daemon: not running${NC}"
        fi
    else
        echo -e "  ${DIM}○ Scanner daemon: N/A (no tmux)${NC}"
    fi
    if [[ -f "$POPUP_PID_FILE" ]] && kill -0 "$(cat "$POPUP_PID_FILE")" 2>/dev/null; then
        local queue_count
        queue_count=$(find "$QUEUE_DIR" -maxdepth 1 -name "*.popup" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}●${NC} Popup daemon:   ${GREEN}running${NC} (PID: $(cat "$POPUP_PID_FILE")) | queue: $queue_count"
    else
        echo -e "  ${DIM}○ Popup daemon:   not running${NC}"
    fi

    # ── NATS / Daemon status from daemon-status.json ──
    if [[ -f "$DAEMON_STATUS_FILE" ]]; then
        echo ""
        echo -e "  ${BOLD}Daemon Status${NC} ${DIM}(from daemon-status.json)${NC}"

        local d_nats d_queue_depth d_active_popup d_uptime d_pid d_heartbeat
        d_nats=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(d.nats||'unknown'); } catch(e) { process.stdout.write('error'); }" 2>/dev/null || echo "error")
        d_queue_depth=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(String(d.queueDepth!=null?d.queueDepth:'?')); } catch(e) { process.stdout.write('?'); }" 2>/dev/null || echo "?")
        d_active_popup=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(d.activePopup||'none'); } catch(e) { process.stdout.write('?'); }" 2>/dev/null || echo "?")
        d_uptime=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(String(d.uptime!=null?d.uptime:'?')); } catch(e) { process.stdout.write('?'); }" 2>/dev/null || echo "?")
        d_pid=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(String(d.pid||'?')); } catch(e) { process.stdout.write('?'); }" 2>/dev/null || echo "?")
        d_heartbeat=$(node -e "try { const d=JSON.parse(require('fs').readFileSync('$DAEMON_STATUS_FILE','utf8')); process.stdout.write(String(d.lastHeartbeat||0)); } catch(e) { process.stdout.write('0'); }" 2>/dev/null || echo "0")

        # Check if daemon is alive (heartbeat within 30s)
        local now_ms
        now_ms=$(node -e "process.stdout.write(String(Date.now()))" 2>/dev/null || echo "0")
        local heartbeat_age_s=999
        if [[ "$d_heartbeat" != "0" && "$now_ms" != "0" ]]; then
            heartbeat_age_s=$(( (now_ms - d_heartbeat) / 1000 ))
        fi

        local daemon_alive_label
        if [[ $heartbeat_age_s -le 30 ]]; then
            daemon_alive_label="${GREEN}alive${NC} (heartbeat ${heartbeat_age_s}s ago)"
        else
            daemon_alive_label="${RED}DEAD${NC} (last heartbeat ${heartbeat_age_s}s ago)"
        fi

        # NATS status color
        local nats_color="$DIM"
        case "$d_nats" in
            connected)    nats_color="$GREEN" ;;
            disconnected) nats_color="$RED" ;;
            file-only)    nats_color="$YELLOW" ;;
        esac

        echo -e "    NATS:          ${nats_color}${d_nats}${NC}"
        echo -e "    Queue depth:   ${d_queue_depth}"
        echo -e "    Active popup:  ${d_active_popup}"
        echo -e "    Uptime:        ${d_uptime}s"
        echo -e "    Daemon PID:    ${d_pid}"
        printf "    Daemon health: "
        echo -e "  ${daemon_alive_label}"
    fi

    # Summary
    if [[ $attention_count -gt 0 ]]; then
        echo ""
        echo -e "  ${RED}${BOLD}$attention_count session(s) need your attention!${NC}"
    fi

    echo ""
}

# ── Focus command ────────────────────────────────────────────────────────────

cmd_focus() {
    local target="${1:-}"

    if [[ -n "$target" ]]; then
        focus_pane "$target"
        echo -e "${GREEN}Focused: $target${NC}"
        return
    fi

    if [[ "$HAS_TMUX" != "true" ]]; then
        activate_terminal
        echo -e "${GREEN}Terminal activated${NC}"
        return
    fi

    # Check hook-based state files first for sessions needing attention
    for state_file in "$SESSION_STATE_DIR"/*; do
        [[ -f "$state_file" ]] || continue
        local s_state="" s_pane=""
        while IFS='=' read -r key val; do
            case "$key" in
                state) s_state="$val" ;;
                pane)  s_pane="$val" ;;
            esac
        done < "$state_file"
        if [[ "$s_state" == "permission" || "$s_state" == "question" ]]; then
            if [[ -n "$s_pane" && "$s_pane" != "no-tmux" && "$s_pane" != "unknown" ]]; then
                focus_pane "$s_pane"
                echo -e "${GREEN}Focused: $s_pane${NC} ($s_state)"
                return
            fi
        fi
    done

    # Fallback: scan tmux panes
    while IFS='|' read -r pane pid attached; do
        local state
        state=$(detect_pane_state "$pane")
        case "$state" in
            permission|question|plan_approval|interrupted)
                focus_pane "$pane"
                echo -e "${GREEN}Focused: $pane${NC} ($state)"
                return
                ;;
        esac
    done < <(find_claude_panes)

    echo -e "${DIM}No sessions currently need attention${NC}"
}

# ── Hook installation ────────────────────────────────────────────────────────

cmd_install() {
    local settings_file="$HOME/.claude/settings.json"
    local hook_script="$WATCHER_DIR/on-claude-notify.sh"

    if [[ ! -f "$hook_script" ]]; then
        echo -e "${RED}Hook script not found: $hook_script${NC}"
        return 1
    fi

    chmod +x "$hook_script"
    chmod +x "$WATCHER_DIR/claude-watcher"

    if [[ ! -f "$settings_file" ]]; then
        echo -e "${RED}Claude settings not found: $settings_file${NC}"
        return 1
    fi

    node << NODESCRIPT
        const fs = require('fs');
        const settings = JSON.parse(fs.readFileSync('$settings_file', 'utf8'));
        const cmd = '$hook_script';

        settings.hooks = settings.hooks || {};

        function addHook(eventName, matcher) {
            const existing = settings.hooks[eventName] || [];
            settings.hooks[eventName] = existing.filter(function(h) {
                var hasOurs = h.hooks && h.hooks.some(function(c) {
                    return c.command && c.command.includes('on-claude-notify');
                });
                return !hasOurs;
            });
            settings.hooks[eventName].push({
                matcher: matcher,
                hooks: [{ type: 'command', command: cmd }]
            });
        }

        // All 12 hook event types (matcher "" = match all)
        addHook('PermissionRequest', '');
        addHook('Elicitation', '');
        addHook('PreToolUse', '');
        addHook('PostToolUse', '');
        addHook('PostToolUseFailure', '');
        addHook('Stop', '');
        addHook('SessionEnd', '');
        addHook('UserPromptSubmit', '');
        addHook('SubagentStart', '');
        addHook('SubagentStop', '');
        addHook('TeammateIdle', '');
        addHook('TaskCompleted', '');

        // Notification with 4 separate matchers
        addHook('Notification', 'permission_prompt');
        addHook('Notification', 'idle_prompt');
        addHook('Notification', 'elicitation_dialog');
        addHook('Notification', 'auth_success');

        fs.writeFileSync('$settings_file', JSON.stringify(settings, null, 2));
NODESCRIPT

    echo -e "${GREEN}Hooks installed successfully!${NC}"
    echo -e "${DIM}  Settings: $settings_file${NC}"
    echo -e "${DIM}  Handler:  $hook_script${NC}"
    echo ""
    echo -e "  ${DIM}Registered 12 event types + 4 Notification matchers:${NC}"
    echo -e "  ${DIM}  PermissionRequest, Elicitation, PreToolUse, PostToolUse,${NC}"
    echo -e "  ${DIM}  PostToolUseFailure, Stop, SessionEnd, UserPromptSubmit,${NC}"
    echo -e "  ${DIM}  SubagentStart, SubagentStop, TeammateIdle, TaskCompleted${NC}"
    echo -e "  ${DIM}  Notification: permission_prompt, idle_prompt, elicitation_dialog, auth_success${NC}"
    echo ""
    if [[ "$HAS_TMUX" == "true" ]]; then
        echo -e "  ${DIM}Mode: full (scanner + hooks + popup dialogs)${NC}"
    else
        echo -e "  ${DIM}Mode: hooks-only (works in any terminal — no tmux required)${NC}"
    fi
    echo -e "  ${YELLOW}Note: Restart running Claude sessions for hooks to take effect.${NC}"
}

cmd_uninstall() {
    local settings_file="$HOME/.claude/settings.json"

    node -e "
        const fs = require('fs');
        const settings = JSON.parse(fs.readFileSync('$settings_file', 'utf8'));

        if (settings.hooks) {
            for (const [key, hooks] of Object.entries(settings.hooks)) {
                settings.hooks[key] = hooks.filter(
                    h => !h.hooks?.some(c => c.command?.includes('on-claude-notify'))
                );
                if (settings.hooks[key].length === 0) delete settings.hooks[key];
            }
            if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
        }

        fs.writeFileSync('$settings_file', JSON.stringify(settings, null, 2));
    "

    echo -e "${GREEN}Hooks removed from Claude settings${NC}"
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    start)          cmd_start "${2:-}" ;;
    stop)           cmd_stop ;;
    status|s)       cmd_status ;;
    focus|f)        cmd_focus "${2:-}" ;;
    install)        cmd_install ;;
    uninstall)      cmd_uninstall ;;
    popup-daemon)   start_popup_daemon; echo -e "${GREEN}Popup daemon started${NC} (PID: $(cat "$POPUP_PID_FILE"))" ;;
    popup-stop)     stop_popup_daemon;  echo -e "${GREEN}Popup daemon stopped${NC}" ;;
    _loop)          run_loop ;;
    help|--help|-h)
        echo ""
        echo -e "  ${BOLD}claude-watcher${NC} — Monitor Claude Code sessions"
        echo ""
        echo -e "  ${BOLD}COMMANDS${NC}"
        echo -e "    start [-d]     Start watching (-d for daemon mode) + popup daemon"
        echo -e "    stop           Stop watcher and popup daemon"
        echo -e "    status         Show all Claude sessions and their state"
        echo -e "    focus [pane]   Bring terminal to front, switch to alerting pane"
        echo -e "    install        Install Claude Code notification hooks"
        echo -e "    uninstall      Remove hooks from Claude settings"
        echo -e "    popup-daemon   Start only the popup daemon"
        echo -e "    popup-stop     Stop only the popup daemon"
        echo ""
        echo -e "  ${BOLD}ENVIRONMENT${NC}"
        echo -e "    CLAUDE_WATCHER_INTERVAL     Scan interval in seconds (default: 3)"
        echo -e "    CLAUDE_WATCHER_SOUND        Sound file path (default: Glass.aiff)"
        echo -e "    CLAUDE_WATCHER_AUTO_FOCUS   Auto-focus on alert (default: true)"
        echo -e "    CLAUDE_WATCHER_COOLDOWN     Repeat alert cooldown in seconds (default: 30)"
        echo ""
        echo -e "  ${BOLD}HOW IT WORKS${NC}"
        echo -e "    Works in two modes depending on your environment:"
        echo ""
        echo -e "    ${GREEN}Hooks-only mode${NC} (any terminal, no tmux needed):"
        echo -e "      Claude fires hook events → GUI popup dialogs → response via stdout"
        echo -e "      PermissionRequest → 3-button dialog (Allow/Deny/Always Allow)"
        echo -e "      Elicitation       → text-input dialog, answer sent to Claude"
        echo ""
        echo -e "    ${GREEN}Full mode${NC} (with tmux):"
        echo -e "      All of the above, plus:"
        echo -e "      Scanner polls tmux panes every ${SCAN_INTERVAL}s for attention indicators"
        echo -e "      Auto-focus switches to the exact tmux pane needing attention"
        echo -e "      Popup queue processes scanner-detected events (FIFO)"
        echo ""
        echo -e "  ${BOLD}QUICK START${NC}"
        echo -e "    claude-watcher install       # Set up Claude hooks"
        echo -e "    claude-watcher start -d      # Start background watcher"
        echo -e "    claude-watcher status        # See all sessions"
        echo ""
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC} — run 'claude-watcher help' for usage"
        exit 1
        ;;
esac
